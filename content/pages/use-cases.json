{
  "slug": "use-cases",
  "bodyClass": "usecases-page",
  "styles": ".usecases-page .hero {\n      background: white;\n      position: relative;\n      overflow: hidden;\n    }\n    .usecases-page .header {\n      border-bottom: 1px solid var(--border);\n    }\n    .usecase-card {\n      background: var(--bg-card);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      padding: 2rem;\n      transition: all 0.3s ease;\n    }\n    .usecase-card:hover {\n      transform: translateY(-4px);\n      box-shadow: 0 12px 40px rgba(79, 70, 229, 0.15);\n      border-color: var(--primary);\n    }\n    .usecase-icon {\n      width: 64px;\n      height: 64px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);\n      border-radius: 16px;\n      margin-bottom: 1.5rem;\n      transition: all 0.3s ease;\n    }\n    .usecase-card:hover .usecase-icon {\n      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);\n    }\n    .usecase-card:hover .usecase-icon svg {\n      stroke: white;\n    }\n    .industry-section {\n      position: relative;\n      overflow: hidden;\n    }\n    .industry-section::before {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      height: 1px;\n      background: linear-gradient(90deg, transparent, var(--border), transparent);\n    }\n    .stat-card {\n      background: var(--bg-card);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      padding: 2rem;\n      text-align: center;\n      transition: all 0.3s ease;\n    }\n    .stat-card:hover {\n      border-color: var(--primary);\n      transform: translateY(-2px);\n    }\n    .stat-number {\n      font-size: 3rem;\n      font-weight: 700;\n      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n      line-height: 1;\n      margin-bottom: 0.5rem;\n    }\n    .comparison-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 2rem;\n    }\n    .comparison-item {\n      display: flex;\n      gap: 1rem;\n      padding: 1.5rem;\n      background: var(--bg-card);\n      border: 1px solid var(--border);\n      border-radius: var(--radius);\n      transition: all 0.3s ease;\n    }\n    .comparison-item:hover {\n      border-color: var(--primary);\n    }\n    .comparison-icon {\n      width: 48px;\n      height: 48px;\n      flex-shrink: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: rgba(79, 70, 229, 0.1);\n      border-radius: 12px;\n    }\n    .testimonial-card {\n      background: var(--bg-card);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      padding: 2rem;\n      transition: all 0.3s ease;\n    }\n    .testimonial-card:hover {\n      border-color: var(--primary);\n      box-shadow: 0 8px 30px rgba(79, 70, 229, 0.1);\n    }\n    .testimonial-header {\n      display: flex;\n      align-items: center;\n      gap: 1rem;\n      margin-bottom: 1rem;\n    }\n    .testimonial-avatar {\n      width: 48px;\n      height: 48px;\n      border-radius: 50%;\n      background: var(--gradient-primary);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      color: white;\n      font-weight: 600;\n    }\n    .workflow-step {\n      display: flex;\n      align-items: flex-start;\n      gap: 1rem;\n      padding: 1.5rem;\n      background: var(--bg-card);\n      border-radius: var(--radius);\n      margin-bottom: 1rem;\n      transition: all 0.3s ease;\n    }\n    .workflow-step:hover {\n      background: var(--bg-secondary);\n    }\n    .step-number {\n      width: 32px;\n      height: 32px;\n      flex-shrink: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: var(--primary);\n      color: white;\n      border-radius: 50%;\n      font-weight: 600;\n      font-size: 0.875rem;\n    }\n    @media (max-width: 1024px) {\n      .comparison-grid {\n        grid-template-columns: 1fr;\n      }\n      .grid[style*=\"repeat(4, 1fr)\"] {\n        grid-template-columns: repeat(2, 1fr) !important;\n      }\n      .grid[style*=\"repeat(3, 1fr)\"] {\n        grid-template-columns: repeat(2, 1fr) !important;\n      }\n      [style*=\"grid-template-columns: repeat(2, 1fr)\"] {\n        grid-template-columns: 1fr !important;\n      }\n    }\n    @media (max-width: 768px) {\n      .usecases-page .hero {\n        padding: 6rem 0 3rem !important;\n      }\n      .hero h1 {\n        font-size: 1.75rem;\n      }\n      .hero-subtitle {\n        font-size: 1rem !important;\n      }\n      .stat-number {\n        font-size: 2.5rem;\n      }\n      .usecase-card {\n        padding: 1.5rem !important;\n      }\n      .section > .container > div[style*=\"grid-template-columns: 1fr 1fr\"] {\n        grid-template-columns: 1fr !important;\n        gap: 2rem !important;\n      }\n      .grid[style*=\"repeat(3, 1fr)\"] {\n        grid-template-columns: repeat(2, 1fr) !important;\n      }\n      [style*=\"grid-template-columns: 1fr 1fr\"] {\n        grid-template-columns: 1fr !important;\n        gap: 2rem !important;\n      }\n      [style*=\"grid-template-columns: repeat(4, 1fr)\"] {\n        grid-template-columns: 1fr !important;\n      }\n      .section-header h2 {\n        font-size: 1.5rem;\n      }\n      .section-header p {\n        font-size: 0.9375rem;\n      }\n      .cta-section {\n        padding: 2rem 1.5rem !important;\n      }\n      .cta-section h2 {\n        font-size: 1.5rem !important;\n      }\n      section.section {\n        padding: 3rem 0 !important;\n      }\n      .comparison-table {\n        font-size: 0.875rem;\n      }\n      .comparison-table th,\n      .comparison-table td {\n        padding: 0.75rem 0.5rem;\n      }\n    }\n    @media (max-width: 576px) {\n      .usecase-icon {\n        width: 56px;\n        height: 56px;\n      }\n      .hero-content {\n        padding: 0 1rem;\n      }\n      .grid[style*=\"repeat(4, 1fr)\"] {\n        grid-template-columns: 1fr !important;\n      }\n      .section {\n        padding: 3rem 0 !important;\n      }\n      .section-header {\n        margin-bottom: 2rem !important;\n      }\n      .btn-lg {\n        padding: 0.75rem 1.5rem;\n        font-size: 0.9375rem;\n      }\n      .industry-section .container > div[style*=\"grid\"] {\n        grid-template-columns: 1fr !important;\n      }\n    }\n    @media (max-width: 480px) {\n      .grid[style*=\"repeat(3, 1fr)\"] {\n        grid-template-columns: 1fr !important;\n      }\n      [style*=\"grid-template-columns: repeat(2, 1fr)\"] {\n        grid-template-columns: 1fr !important;\n      }\n      .hero-actions {\n        flex-direction: column;\n        width: 100%;\n      }\n      .hero-actions .btn {\n        width: 100%;\n        justify-content: center;\n      }\n    }\n    @media (max-width: 375px) {\n      .section-header h2 {\n        font-size: 1.25rem;\n      }\n      .usecase-card h3 {\n        font-size: 1rem !important;\n      }\n      .usecase-card p {\n        font-size: 0.875rem !important;\n      }\n    }",
  "content": "\n    <section class=\"hero\" style=\"padding: 8rem 0 5rem;\">\n      <div class=\"container\">\n        <div class=\"hero-content\" style=\"text-align: center; max-width: 900px; margin: 0 auto; padding: 0 1rem;\">\n          <div class=\"badge badge-primary mb-4 fade-in\">Industry Solutions</div>\n          <h1 class=\"fade-in\" style=\"margin-bottom: 1.5rem;\">Built for <span class=\"text-gradient\">Every Industry</span></h1>\n          <p class=\"hero-subtitle fade-in delay-100\" style=\"font-size: 1.25rem; margin-bottom: 2rem; color: var(--text-secondary);\">ZyncSpace adapts to how your team works. Whether you're a lean startup or a growing enterprise, we've got you covered.</p>\n          <div class=\"hero-actions fade-in delay-200\" style=\"justify-content: center; flex-wrap: wrap; gap: 16px;\">\n            <a href=\"https://chat.zyncspace.com/signup\" class=\"btn btn-primary btn-lg\">Start Free Trial <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg></a>\n            <a href=\"#startups\" class=\"btn btn-secondary btn-lg\">Explore Solutions</a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"startups\" class=\"section industry-section\" style=\"padding: 5rem 0;\">\n      <div class=\"container\">\n        <div class=\"grid\" style=\"grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;\">\n          <div class=\"fade-in\">\n            <div class=\"badge badge-primary mb-3\">For Startups</div>\n            <h2>Move Fast, Stay <span class=\"text-gradient\">Connected</span></h2>\n            <p class=\"text-secondary mt-4\" style=\"font-size: 1.125rem; line-height: 1.8;\">A clutter-free workspace built for lean teams to plan, execute, and communicate—all in one place. Perfect for startups that need to move fast without sacrificing collaboration.</p>\n            \n            <div style=\"margin-top: 2rem;\">\n              <div class=\"comparison-item\">\n                <div class=\"comparison-icon\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                </div>\n                <div>\n                  <h4 style=\"font-size: 1rem; margin-bottom: 0.25rem;\">Rapid Team Onboarding</h4>\n                  <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Import entire teams with bulk CSV upload in minutes, not hours.</p>\n                </div>\n              </div>\n              \n              <div class=\"comparison-item\" style=\"margin-top: 1rem;\">\n                <div class=\"comparison-icon\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                </div>\n                <div>\n                  <h4 style=\"font-size: 1rem; margin-bottom: 0.25rem;\">Real-Time Collaboration</h4>\n                  <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Work together on tasks and projects without the back-and-forth of email.</p>\n                </div>\n              </div>\n              \n              <div class=\"comparison-item\" style=\"margin-top: 1rem;\">\n                <div class=\"comparison-icon\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                </div>\n                <div>\n                  <h4 style=\"font-size: 1rem; margin-bottom: 0.25rem;\">Built-In AI</h4>\n                  <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Let AI handle summarization and rewriting so you can focus on what matters.</p>\n                </div>\n              </div>\n            </div>\n            \n            <a href=\"https://chat.zyncspace.com/signup\" class=\"btn btn-primary mt-5\">Get Started Free <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg></a>\n          </div>\n          \n          <div class=\"fade-in delay-200\">\n            <div class=\"usecase-card\" style=\"background: var(--bg-card);\">\n              <div style=\"text-align: center; margin-bottom: 2rem;\">\n                <div class=\"stat-number\" style=\"font-size: 4rem;\">56%</div>\n                <div style=\"color: var(--text-secondary); font-weight: 500;\">Higher Productivity</div>\n              </div>\n              <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;\">\n                <div style=\"text-align: center; padding: 1.25rem; background: var(--bg-secondary); border-radius: var(--radius);\">\n                  <div style=\"font-size: 1.75rem; font-weight: 700; color: var(--primary);\">3x</div>\n                  <div style=\"font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;\">Faster Planning</div>\n                </div>\n                <div style=\"text-align: center; padding: 1.25rem; background: var(--bg-secondary); border-radius: var(--radius);\">\n                  <div style=\"font-size: 1.75rem; font-weight: 700; color: var(--primary);\">60%</div>\n                  <div style=\"font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;\">Less Tool Switching</div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" style=\"padding: 5rem 0; background: var(--bg-secondary);\">\n      <div class=\"container\">\n        <div class=\"grid\" style=\"grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;\">\n          <div class=\"fade-in\">\n            <div class=\"usecase-card\" style=\"background: var(--bg-card);\">\n              <h4 style=\"font-size: 1rem; margin-bottom: 1.5rem; text-align: center;\">Startup Workflow</h4>\n              <div class=\"workflow-step\">\n                <div class=\"step-number\">1</div>\n                <div>\n                  <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.25rem;\">Create Your Workspace</h5>\n                  <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Set up your team workspace in under 2 minutes</p>\n                </div>\n              </div>\n              <div class=\"workflow-step\">\n                <div class=\"step-number\">2</div>\n                <div>\n                  <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.25rem;\">Import Team Members</h5>\n                  <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Bulk upload with CSV or invite individually</p>\n                </div>\n              </div>\n              <div class=\"workflow-step\">\n                <div class=\"step-number\">3</div>\n                <div>\n                  <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.25rem;\">Set Up Channels</h5>\n                  <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Create channels for teams, projects, and topics</p>\n                </div>\n              </div>\n              <div class=\"workflow-step\" style=\"margin-bottom: 0;\">\n                <div class=\"step-number\">4</div>\n                <div>\n                  <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.25rem;\">Start Collaborating</h5>\n                  <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Dive in and start getting things done</p>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"fade-in delay-200\">\n            <div class=\"badge badge-primary mb-3\">Why Startups Choose Us</div>\n            <h2>Everything You Need to <span class=\"text-gradient\">Scale</span></h2>\n            <p class=\"text-secondary mt-4\" style=\"font-size: 1.125rem; line-height: 1.8;\">Startups need tools that grow with them. ZyncSpace starts free and scales as you do, without the complexity of enterprise software.</p>\n            \n            <ul style=\"margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem;\">\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Free during beta—no credit card required\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Up to 10 users on free plan\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Real-time task tracking with Kanban boards\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Built-in video conferencing\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                AI-powered writing assistance\n              </li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"education\" class=\"section industry-section\" style=\"padding: 5rem 0;\">\n      <div class=\"container\">\n        <div class=\"grid\" style=\"grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;\">\n          <div class=\"fade-in\">\n            <div class=\"badge badge-primary mb-3\">For Education</div>\n            <h2>Better Learning Through <span class=\"text-gradient\">Collaboration</span></h2>\n            <p class=\"text-secondary mt-4\" style=\"font-size: 1.125rem; line-height: 1.8;\">All-in-one space for structured lesson plans, smooth student teamwork, and clear communication. Built for classrooms, training programs, and online courses.</p>\n            \n            <div style=\"margin-top: 2rem;\">\n              <div class=\"comparison-item\">\n                <div class=\"comparison-icon\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"></path><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"></path></svg>\n                </div>\n                <div>\n                  <h4 style=\"font-size: 1rem; margin-bottom: 0.25rem;\">Lesson Plan Channels</h4>\n                  <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Structured channels for each course module and topic.</p>\n                </div>\n              </div>\n              \n              <div class=\"comparison-item\" style=\"margin-top: 1rem;\">\n                <div class=\"comparison-icon\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg>\n                </div>\n                <div>\n                  <h4 style=\"font-size: 1rem; margin-bottom: 0.25rem;\">Student Collaboration</h4>\n                  <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Group projects with threaded discussions and file sharing.</p>\n                </div>\n              </div>\n              \n              <div class=\"comparison-item\" style=\"margin-top: 1rem;\">\n                <div class=\"comparison-icon\">\n                  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\" ry=\"2\"></rect><line x1=\"9\" y1=\"3\" x2=\"9\" y2=\"21\"></line><line x1=\"15\" y1=\"3\" x2=\"15\" y2=\"21\"></line></svg>\n                </div>\n                <div>\n                  <h4 style=\"font-size: 1rem; margin-bottom: 0.25rem;\">Assignment Tracking</h4>\n                  <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Visual Kanban boards for homework and deadline management.</p>\n                </div>\n              </div>\n            </div>\n            \n            <a href=\"https://chat.zyncspace.com/signup\" class=\"btn btn-primary mt-5\">Get Started Free <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg></a>\n          </div>\n          \n          <div class=\"fade-in delay-200\">\n            <div class=\"usecase-card\" style=\"background: var(--bg-card);\">\n              <div style=\"display: flex; flex-direction: column; gap: 1rem;\">\n                <div class=\"comparison-item\" style=\"margin: 0;\">\n                  <div class=\"comparison-icon\" style=\"background: rgba(34, 197, 94, 0.1);\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                  </div>\n                  <div>\n                    <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Bulk Student Enrollment</h5>\n                    <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Import entire classes with CSV files</p>\n                  </div>\n                </div>\n                \n                <div class=\"comparison-item\" style=\"margin: 0;\">\n                  <div class=\"comparison-icon\" style=\"background: rgba(59, 130, 246, 0.1);\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#3b82f6\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                  </div>\n                  <div>\n                    <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Resource Library</h5>\n                    <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Share files and documents easily</p>\n                  </div>\n                </div>\n                \n                <div class=\"comparison-item\" style=\"margin: 0;\">\n                  <div class=\"comparison-icon\" style=\"background: rgba(139, 92, 246, 0.1);\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#8b5cf6\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                  </div>\n                  <div>\n                    <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Direct Messaging</h5>\n                    <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Private student-teacher communication</p>\n                  </div>\n                </div>\n                \n                <div class=\"comparison-item\" style=\"margin: 0;\">\n                  <div class=\"comparison-icon\" style=\"background: rgba(236, 72, 153, 0.1);\">\n                    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ec4899\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                  </div>\n                  <div>\n                    <h5 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Calendar Integration</h5>\n                    <p style=\"font-size: 0.8125rem; color: var(--text-secondary); margin: 0;\">Sync schedules and deadlines</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section id=\"agencies\" class=\"section\" style=\"padding: 5rem 0; background: var(--bg-secondary);\">\n      <div class=\"container\">\n        <div class=\"grid\" style=\"grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;\">\n          <div class=\"fade-in\">\n            <div class=\"usecase-card\" style=\"background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); color: white;\">\n              <h4 style=\"color: white; margin-bottom: 1.5rem;\">Agency Workflow</h4>\n              <div style=\"display: flex; flex-direction: column; gap: 1rem;\">\n                <div style=\"display: flex; align-items: center; gap: 1rem;\">\n                  <span style=\"width: 36px; height: 36px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;\">1</span>\n                  <div>\n                    <h5 style=\"font-size: 1rem; margin-bottom: 0.125rem; color: white;\">Create Client Workspace</h5>\n                    <p style=\"font-size: 0.8125rem; opacity: 0.9; margin: 0;\">Dedicated space for each client project</p>\n                  </div>\n                </div>\n                <div style=\"display: flex; align-items: center; gap: 1rem;\">\n                  <span style=\"width: 36px; height: 36px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;\">2</span>\n                  <div>\n                    <h5 style=\"font-size: 1rem; margin-bottom: 0.125rem; color: white;\">Invite Team & Clients</h5>\n                    <p style=\"font-size: 0.8125rem; opacity: 0.9; margin: 0;\">Guest access for seamless collaboration</p>\n                  </div>\n                </div>\n                <div style=\"display: flex; align-items: center; gap: 1rem;\">\n                  <span style=\"width: 36px; height: 36px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;\">3</span>\n                  <div>\n                    <h5 style=\"font-size: 1rem; margin-bottom: 0.125rem; color: white;\">Organize by Project</h5>\n                    <p style=\"font-size: 0.8125rem; opacity: 0.9; margin: 0;\">Channels and boards for every deliverable</p>\n                  </div>\n                </div>\n                <div style=\"display: flex; align-items: center; gap: 1rem;\">\n                  <span style=\"width: 36px; height: 36px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; flex-shrink: 0;\">4</span>\n                  <div>\n                    <h5 style=\"font-size: 1rem; margin-bottom: 0.125rem; color: white;\">Track & Deliver</h5>\n                    <p style=\"font-size: 0.8125rem; opacity: 0.9; margin: 0;\">Kanban boards for project visibility</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"fade-in delay-200\">\n            <div class=\"badge badge-primary mb-3\">For Agencies</div>\n            <h2>Client Communication <span class=\"text-gradient\">Simplified</span></h2>\n            <p class=\"text-secondary mt-4\" style=\"font-size: 1.125rem; line-height: 1.8;\">ZyncSpace delivers secure, real-time communication for internal teams and external clients. Keep everyone aligned without the email chaos.</p>\n            \n            <ul style=\"margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem;\">\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Guest access for client collaboration\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Project-specific workspaces and channels\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                File sharing with version control\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Role-based permissions for security\n              </li>\n              <li style=\"display: flex; align-items: center; gap: 0.75rem; color: var(--text-secondary);\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--success)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                Built-in video calls for client meetings\n              </li>\n            </ul>\n            \n            <a href=\"https://chat.zyncspace.com/signup\" class=\"btn btn-primary mt-5\">Get Started Free <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg></a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section industry-section\" style=\"padding: 5rem 0;\">\n      <div class=\"container\">\n        <div class=\"section-header fade-in\" style=\"margin-bottom: 4rem;\">\n          <div class=\"badge badge-primary mb-3\">More Industries</div>\n          <h2>Built for <span class=\"text-gradient\">Every Team</span></h2>\n          <p>ZyncSpace adapts to your industry's unique needs.</p>\n        </div>\n        \n        <div class=\"grid\" style=\"grid-template-columns: repeat(3, 1fr); gap: 2rem;\">\n          <div class=\"usecase-card fade-in\">\n            <div class=\"usecase-icon\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"></path><polyline points=\"9 22 9 12 15 12 15 22\"></polyline></svg>\n            </div>\n            <h3 style=\"font-size: 1.125rem; margin-bottom: 0.75rem;\">Healthcare</h3>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">Secure messaging for medical teams, care coordination, and patient communication with HIPAA-compliant features.</p>\n          </div>\n          \n          <div class=\"usecase-card fade-in delay-100\">\n            <div class=\"usecase-icon\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\"></rect><path d=\"M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16\"></path></svg>\n            </div>\n            <h3 style=\"font-size: 1.125rem; margin-bottom: 0.75rem;\">Real Estate</h3>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">Coordinate property showings, client updates, and team communications all in one place.</p>\n          </div>\n          \n          <div class=\"usecase-card fade-in delay-200\">\n            <div class=\"usecase-icon\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polygon points=\"10 8 16 12 10 16 10 8\"></polygon></svg>\n            </div>\n            <h3 style=\"font-size: 1.125rem; margin-bottom: 0.75rem;\">Media & Entertainment</h3>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">Creative collaboration, content planning, and production workflow management.</p>\n          </div>\n          \n          <div class=\"usecase-card fade-in\">\n            <div class=\"usecase-icon\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"1\" y=\"4\" width=\"22\" height=\"16\" rx=\"2\" ry=\"2\"></rect><line x1=\"1\" y1=\"10\" x2=\"23\" y2=\"10\"></line></svg>\n            </div>\n            <h3 style=\"font-size: 1.125rem; margin-bottom: 0.75rem;\">Financial Services</h3>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">Secure internal communications with audit trails and compliance-ready features.</p>\n          </div>\n          \n          <div class=\"usecase-card fade-in delay-100\">\n            <div class=\"usecase-icon\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"></path><polyline points=\"14 2 14 8 20 8\"></polyline></svg>\n            </div>\n            <h3 style=\"font-size: 1.125rem; margin-bottom: 0.75rem;\">Consulting</h3>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">Manage multiple client engagements with dedicated workspaces and project tracking.</p>\n          </div>\n          \n          <div class=\"usecase-card fade-in delay-200\">\n            <div class=\"usecase-icon\">\n              <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--primary)\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2L2 7l10 5 10-5-10-5z\"></path><path d=\"M2 17l10 5 10-5\"></path><path d=\"M2 12l10 5 10-5\"></path></svg>\n            </div>\n            <h3 style=\"font-size: 1.125rem; margin-bottom: 0.75rem;\">Nonprofits</h3>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">Coordinate volunteers, manage campaigns, and improve donor communications.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" style=\"padding: 5rem 0; background: var(--bg-secondary);\">\n      <div class=\"container\">\n        <div class=\"section-header fade-in\" style=\"margin-bottom: 4rem;\">\n          <h2>What Our Customers <span class=\"text-gradient\">Say</span></h2>\n          <p>Real feedback from teams using ZyncSpace.</p>\n        </div>\n        \n        <div class=\"grid\" style=\"grid-template-columns: repeat(3, 1fr); gap: 2rem;\">\n          <div class=\"testimonial-card fade-in\">\n            <div class=\"testimonial-header\">\n              <div class=\"testimonial-avatar\">SK</div>\n              <div>\n                <h4 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Sarah Kim</h4>\n                <p style=\"font-size: 0.8125rem; color: var(--text-muted); margin: 0;\">Product Manager, TechStart</p>\n              </div>\n            </div>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">\"ZyncSpace completely transformed how our remote team communicates. We've eliminated endless email chains and finally have everything in one place.\"</p>\n          </div>\n          \n          <div class=\"testimonial-card fade-in delay-100\">\n            <div class=\"testimonial-header\">\n              <div class=\"testimonial-avatar\">MR</div>\n              <div>\n                <h4 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Michael Rodriguez</h4>\n                <p style=\"font-size: 0.8125rem; color: var(--text-muted); margin: 0;\">Founder, Digital Agency Pro</p>\n              </div>\n            </div>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">\"Managing multiple client projects used to be chaos. Now with ZyncSpace, our team stays organized and clients love the transparency.\"</p>\n          </div>\n          \n          <div class=\"testimonial-card fade-in delay-200\">\n            <div class=\"testimonial-header\">\n              <div class=\"testimonial-avatar\">EJ</div>\n              <div>\n                <h4 style=\"font-size: 0.9375rem; margin-bottom: 0.125rem;\">Emily Johnson</h4>\n                <p style=\"font-size: 0.8125rem; color: var(--text-muted); margin: 0;\">Operations Lead, ScaleUp</p>\n              </div>\n            </div>\n            <p style=\"font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;\">\"We switched from Slack and never looked back. ZyncSpace's Kanban integration means we don't need a separate task management tool anymore.\"</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" style=\"padding: 5rem 0;\">\n      <div class=\"container\">\n        <div class=\"section-header fade-in\" style=\"margin-bottom: 4rem;\">\n          <h2>Results That <span class=\"text-gradient\">Matter</span></h2>\n          <p>Real results from real teams using ZyncSpace.</p>\n        </div>\n        \n        <div class=\"grid\" style=\"grid-template-columns: repeat(4, 1fr); gap: 2rem;\">\n          <div class=\"stat-card fade-in\">\n            <div class=\"stat-number\">56%</div>\n            <div style=\"font-weight: 600; margin-bottom: 0.5rem;\">Higher Productivity</div>\n            <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Teams report significant productivity gains</p>\n          </div>\n          \n          <div class=\"stat-card fade-in delay-100\">\n            <div class=\"stat-number\">42%</div>\n            <div style=\"font-weight: 600; margin-bottom: 0.5rem;\">Faster Task Completion</div>\n            <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Projects completed 42% faster on average</p>\n          </div>\n          \n          <div class=\"stat-card fade-in delay-200\">\n            <div class=\"stat-number\">3x</div>\n            <div style=\"font-weight: 600; margin-bottom: 0.5rem;\">Better Scheduling</div>\n            <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Calendar sync reduces scheduling conflicts</p>\n          </div>\n          \n          <div class=\"stat-card fade-in delay-300\">\n            <div class=\"stat-number\">60%</div>\n            <div style=\"font-weight: 600; margin-bottom: 0.5rem;\">Fewer Tools Needed</div>\n            <p style=\"font-size: 0.875rem; color: var(--text-secondary); margin: 0;\">Consolidate your software stack</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"section\" style=\"padding: 5rem 0; background: var(--bg-secondary);\">\n      <div class=\"container\">\n        <div class=\"cta-section fade-in\" style=\"text-align: center; padding: 4rem 2rem; background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); border-radius: var(--radius-lg);\">\n          <h2 style=\"color: white; margin-bottom: 1rem;\">Ready to Transform Your Team?</h2>\n          <p style=\"color: rgba(255,255,255,0.9); font-size: 1.125rem; margin-bottom: 2rem;\">Join thousands of teams already using ZyncSpace. Free during beta, no credit card required.</p>\n          <div style=\"display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;\">\n            <a href=\"https://chat.zyncspace.com/signup\" class=\"btn btn-lg\" style=\"background: white; color: var(--primary);\">Start Free <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"></line><polyline points=\"12 5 19 12 12 19\"></polyline></svg></a>\n            <a href=\"https://forms.gle/QVfnCHigc7NS3Z2K6\" class=\"btn btn-lg\" style=\"background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);\">Book a Demo</a>\n          </div>\n        </div>\n      </div>\n    </section>\n  ",
