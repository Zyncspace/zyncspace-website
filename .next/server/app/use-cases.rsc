            <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0;">Calendar sync reduces scheduling conflicts</p>
          </div>
          
          <div class="stat-card fade-in delay-300">
            <div class="stat-number">60%</div>
            <div style="font-weight: 600; margin-bottom: 0.5rem;">Fewer Tools Needed</div>
            <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0;">Consolidate your software stack</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="padding: 5rem 0; background: var(--bg-secondary);">
      <div class="container">
        <div class="cta-section fade-in" style="text-align: center; padding: 4rem 2rem; background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); border-radius: var(--radius-lg);">
          <h2 style="color: white; margin-bottom: 1rem;">Ready to Transform Your Team?</h2>
          <p style="color: rgba(255,255,255,0.9); font-size: 1.125rem; margin-bottom: 2rem;">Join thousands of teams already using ZyncSpace. Free during beta, no credit card required.</p>
          <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap;">
            <a href="https://chat.zyncspace.com/signup" class="btn btn-lg" style="background: white; color: var(--primary);">Start Free <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
            <a href="https://forms.gle/QVfnCHigc7NS3Z2K6" class="btn btn-lg" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);">Book a Demo</a>
          </div>
        </div>
      </div>
    </section>
