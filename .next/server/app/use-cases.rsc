10:T1b78,.usecases-page .hero {
      background: white;
      position: relative;
      overflow: hidden;
    }
    .usecases-page .header {
      border-bottom: 1px solid var(--border);
    }
    .usecase-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      transition: all 0.3s ease;
    }
    .usecase-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(79, 70, 229, 0.15);
      border-color: var(--primary);
    }
    .usecase-icon {
      width: 64px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, rgba(79, 70, 229, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
      border-radius: 16px;
      margin-bottom: 1.5rem;
      transition: all 0.3s ease;
    }
    .usecase-card:hover .usecase-icon {
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    }
    .usecase-card:hover .usecase-icon svg {
      stroke: white;
    }
    .industry-section {
      position: relative;
      overflow: hidden;
    }
    .industry-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
    }
    .stat-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      text-align: center;
      transition: all 0.3s ease;
    }
    .stat-card:hover {
      border-color: var(--primary);
      transform: translateY(-2px);
    }
    .stat-number {
      font-size: 3rem;
      font-weight: 700;
      background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .comparison-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
    .comparison-item {
      display: flex;
      gap: 1rem;
      padding: 1.5rem;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      transition: all 0.3s ease;
    }
    .comparison-item:hover {
      border-color: var(--primary);
    }
    .comparison-icon {
      width: 48px;
      height: 48px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(79, 70, 229, 0.1);
      border-radius: 12px;
    }
    .testimonial-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      transition: all 0.3s ease;
    }
    .testimonial-card:hover {
      border-color: var(--primary);
      box-shadow: 0 8px 30px rgba(79, 70, 229, 0.1);
    }
    .testimonial-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .testimonial-avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--gradient-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 600;
    }
    .workflow-step {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.5rem;
      background: var(--bg-card);
      border-radius: var(--radius);
      margin-bottom: 1rem;
      transition: all 0.3s ease;
    }
    .workflow-step:hover {
      background: var(--bg-secondary);
    }
    .step-number {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--primary);
      color: white;
      border-radius: 50%;
      font-weight: 600;
      font-size: 0.875rem;
    }
    @media (max-width: 1024px) {
      .comparison-grid {
        grid-template-columns: 1fr;
      }
      .grid[style*="repeat(4, 1fr)"] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      .grid[style*="repeat(3, 1fr)"] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      [style*="grid-template-columns: repeat(2, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
    }
    @media (max-width: 768px) {
      .usecases-page .hero {
        padding: 6rem 0 3rem !important;
      }
      .hero h1 {
        font-size: 1.75rem;
      }
      .hero-subtitle {
        font-size: 1rem !important;
      }
      .stat-number {
        font-size: 2.5rem;
      }
      .usecase-card {
        padding: 1.5rem !important;
      }
      .section > .container > div[style*="grid-template-columns: 1fr 1fr"] {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
      .grid[style*="repeat(3, 1fr)"] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      [style*="grid-template-columns: 1fr 1fr"] {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
      [style*="grid-template-columns: repeat(4, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
      .section-header h2 {
        font-size: 1.5rem;
      }
      .section-header p {
        font-size: 0.9375rem;
      }
      .cta-section {
        padding: 2rem 1.5rem !important;
      }
      .cta-section h2 {
        font-size: 1.5rem !important;
      }
      section.section {
        padding: 3rem 0 !important;
      }
      .comparison-table {
        font-size: 0.875rem;
      }
      .comparison-table th,
      .comparison-table td {
        padding: 0.75rem 0.5rem;
      }
    }
    @media (max-width: 576px) {
      .usecase-icon {
        width: 56px;
        height: 56px;
      }
      .hero-content {
        padding: 0 1rem;
      }
      .grid[style*="repeat(4, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
      .section {
        padding: 3rem 0 !important;
      }
      .section-header {
        margin-bottom: 2rem !important;
      }
      .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 0.9375rem;
      }
      .industry-section .container > div[style*="grid"] {
        grid-template-columns: 1fr !important;
      }
    }
    @media (max-width: 480px) {
      .grid[style*="repeat(3, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
      [style*="grid-template-columns: repeat(2, 1fr)"] {
        grid-template-columns: 1fr !important;
      }
      .hero-actions {
        flex-direction: column;
        width: 100%;
      }
      .hero-actions .btn {
        width: 100%;
        justify-content: center;
      }
    }
    @media (max-width: 375px) {
      .section-header h2 {
        font-size: 1.25rem;
      }
      .usecase-card h3 {
        font-size: 1rem !important;
      }
      .usecase-card p {
        font-size: 0.875rem !important;
      }
