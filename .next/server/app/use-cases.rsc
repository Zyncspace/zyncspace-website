18:T81f0,
    <section id="startups" class="section industry-section" style="padding: 5rem 0;">
      <div class="container">
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
          <div class="fade-in">
            <div class="badge badge-primary mb-3">For Startups</div>
            <h2>Move Fast, Stay <span class="text-gradient">Connected</span></h2>
            <p class="text-secondary mt-4" style="font-size: 1.125rem; line-height: 1.8;">A clutter-free workspace built for lean teams to plan, execute, and communicate—all in one place. Perfect for startups that need to move fast without sacrificing collaboration.</p>
            
            <div style="margin-top: 2rem;">
              <div class="comparison-item">
                <div class="comparison-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <div>
                  <h4 style="font-size: 1rem; margin-bottom: 0.25rem;">Rapid Team Onboarding</h4>
                  <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0;">Import entire teams with bulk CSV upload in minutes, not hours.</p>
                </div>
              </div>
              
              <div class="comparison-item" style="margin-top: 1rem;">
                <div class="comparison-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <div>
                  <h4 style="font-size: 1rem; margin-bottom: 0.25rem;">Real-Time Collaboration</h4>
                  <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0;">Work together on tasks and projects without the back-and-forth of email.</p>
                </div>
              </div>
              
              <div class="comparison-item" style="margin-top: 1rem;">
                <div class="comparison-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <div>
                  <h4 style="font-size: 1rem; margin-bottom: 0.25rem;">Built-In AI</h4>
                  <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0;">Let AI handle summarization and rewriting so you can focus on what matters.</p>
                </div>
              </div>
            </div>
            
            <a href="https://chat.zyncspace.com/signup" class="btn btn-primary mt-5">Get Started Free <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
          </div>
          
          <div class="fade-in delay-200">
            <div class="usecase-card" style="background: var(--bg-card);">
              <div style="text-align: center; margin-bottom: 2rem;">
                <div class="stat-number" style="font-size: 4rem;">56%</div>
                <div style="color: var(--text-secondary); font-weight: 500;">Higher Productivity</div>
              </div>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div style="text-align: center; padding: 1.25rem; background: var(--bg-secondary); border-radius: var(--radius);">
                  <div style="font-size: 1.75rem; font-weight: 700; color: var(--primary);">3x</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">Faster Planning</div>
                </div>
                <div style="text-align: center; padding: 1.25rem; background: var(--bg-secondary); border-radius: var(--radius);">
                  <div style="font-size: 1.75rem; font-weight: 700; color: var(--primary);">60%</div>
                  <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem;">Less Tool Switching</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="padding: 5rem 0; background: var(--bg-secondary);">
      <div class="container">
        <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
          <div class="fade-in">
            <div class="usecase-card" style="background: var(--bg-card);">
              <h4 style="font-size: 1rem; margin-bottom: 1.5rem; text-align: center;">Startup Workflow</h4>
              <div class="workflow-step">
                <div class="step-number">1</div>
                <div>
                  <h5 style="font-size: 0.9375rem; margin-bottom: 0.25rem;">Create Your Workspace</h5>
                  <p style="font-size: 0.8125rem; color: var(--text-secondary); margin: 0;">Set up your team workspace in under 2 minutes</p>
                </div>
              </div>
              <div class="workflow-step">
                <div class="step-number">2</div>
                <div>
                  <h5 style="font-size: 0.9375rem; margin-bottom: 0.25rem;">Import Team Members</h5>
