{
  "name": "zyncspace-india",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.13.1",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node scripts/check-node.mjs && node scripts/prepare-dev.mjs && next dev",
    "compress:assets": "node scripts/compress-assets.mjs",
    "build": "node scripts/check-node.mjs && node scripts/extract-product-content.mjs && next build && node scripts/generate-seo-files.mjs && node scripts/seo-audit.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && biome check .",
    "lint:fix": "eslint . --fix && biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check:knip": "knip",
    "check:jscpd": "jscpd .",
    "check:circular": "madge --circular --extensions ts,tsx app components lib",
    "check:deps": "depcruise app components lib --config .dependency-cruiser.cjs",
    "check:seo": "node scripts/seo-audit.mjs",
    "extract": "node scripts/extract-product-content.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reading-time": "^1.5.0",
    "schema-dts": "^2.0.0",
    "simple-icons": "^15.22.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-sonarjs": "^4.1.0",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "jsdom": "^29.1.1",
    "knip": "^6.22.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
